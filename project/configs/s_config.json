{
  "data": {
    "dataset_path": "project/data/dataset.xlsx",
    "date_col": "dateByOurs",
    "target_col": "Ypowerconsumption"
  },
  "tune": {
    "tune_start": "2019-01-01",
    "tune_end": "2019-09-30",
    "n_trials": 1,
    "metric_mape_weight": 0.6,
    "metric_r2_weight": 0.4,
    "output_dir": "artefakts/results/allday"
  },
  "model": {
    "name": "allday",
    "train_days": 90,
    "max_windows": 40,
    "window_step_days": 7,
    "lgbm_search_space": {
      "num_leaves": {"type": "int", "low": 64, "high": 255},
      "n_estimators": {"type": "int", "low": 400, "high": 2000},
      "learning_rate": {"type": "float", "low": 0.003, "high": 0.05, "log": true},
      "min_child_samples": {"type": "int", "low": 10, "high": 60},
      "subsample": {"type": "float", "low": 0.6, "high": 1},
      "colsample_bytree": {"type": "float", "low": 0.6, "high": 1},
      "reg_alpha": {"type": "float", "low": 0, "high": 1},
      "reg_lambda": {"type": "float", "low": 0, "high": 3}
    }
  },
  "forecast": {
    "train_start": "2020-01-02",
    "train_end": "2021-12-31",
    "forecast_start": "2022-01-01",
    "forecast_end": "2022-01-30",
    "output_dir": "artefakts/test_results_allday_web"
  }
}
